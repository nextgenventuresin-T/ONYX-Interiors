# Copy to server/.env for local dev, or set these in Render's dashboard.

# Neon Postgres connection string (from the Neon dashboard → Connection Details).
# Example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Token that protects GET /api/contacts (so only you can read enquiries).
# Use any long random string. Render can auto-generate this.
ADMIN_TOKEN=

# Render sets PORT automatically; locally it defaults to 5000.
# PORT=5000
